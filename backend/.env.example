# ============================================================
#  PWIN AI — environment configuration
#  Copy this file to ".env" and fill in what you need.
#  Everything has a working default; the app runs with NO keys.
# ============================================================

# ---- Server ----
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ---- Database (XAMPP MySQL) ----
# In XAMPP the default is user "root" with an EMPTY password.
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pwin_ai
# Or override completely:
# DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/pwin_ai?charset=utf8mb4
# If MySQL is unreachable, the app falls back to a local SQLite file:
USE_SQLITE_FALLBACK=true

# ---- Weather providers ----
# Open-Meteo is the default and needs NO key.
PRIMARY_PROVIDER=open-meteo
# Optional upgrades:
OPENWEATHER_API_KEY=
WEATHERAPI_KEY=

# ---- AI (optional) ----
# Without a key, a built-in rule-based meteorological explainer is used.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Map (optional) ----
# Leaflet + free tiles are used by default. Provide a token to use Mapbox.
MAPBOX_TOKEN=

# ---- Refresh ----
REFRESH_INTERVAL_SECONDS=600
FETCH_CONCURRENCY=8

# ---- Security ----
SECRET_KEY=change-me-in-production
CORS_ORIGINS=*
